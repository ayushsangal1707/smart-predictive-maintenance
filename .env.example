# Copy this file to .env and fill in real values. Never commit the real .env.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Comma-separated, required in production if serving over HTTPS behind a
# custom domain, e.g. https://maintenance.example.com
CSRF_TRUSTED_ORIGINS=
# Set to False only if TLS is terminated somewhere Django can't detect via
# X-Forwarded-Proto (uncommon — leave True for standard Docker/nginx setups).
DJANGO_SECURE_SSL_REDIRECT=True

DB_NAME=smart_maintenance_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@smartmaintenance.local
